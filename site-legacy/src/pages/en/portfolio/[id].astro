---
import Layout from '@/layouts/Layout.astro';
import SiteHeader from '@/components/layout/SiteHeader.astro';
import SiteFooter from '@/components/layout/SiteFooter.astro';
import TangleCursor from '@/components/cursor/TangleCursor';
import artworks from '@/data/artworks.json';
import { drawTile } from '@/lib/tangles';

export async function getStaticPaths() {
  return artworks.map(artwork => ({
    params: { id: artwork.id.toString() },
    props: { artwork }
  }));
}

interface Props {
  artwork: typeof artworks[0];
}

const { artwork } = Astro.props as Props;
const lang = 'en';
const currentPath = `/en/portfolio/${artwork.id}`;
const title = `Zentangle Chou — ${artwork.titleEn}`;
const description = artwork.descEn;

const currentIndex = artworks.findIndex(a => a.id === artwork.id);
const prevArtwork = currentIndex > 0 ? artworks[currentIndex - 1] : artworks[artworks.length - 1];
const nextArtwork = currentIndex < artworks.length - 1 ? artworks[currentIndex + 1] : artworks[0];

const dateObj = new Date(artwork.date);
const dateStr = dateObj.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const hasRealImage = artwork.full && !artwork.full.endsWith('.svg');
const proceduralTile = !hasRealImage
  ? drawTile({ seed: `artwork-${artwork.id}-${artwork.titleEn}`, size: 800, tangles: artwork.tangles.map(t => t.toLowerCase().replace(/\s+/g, '-')) as any })
  : null;
---

<Layout
  title={title}
  description={description}
  ogImage={artwork.full}
  lang={lang}
  currentPath={currentPath}
>
  <SiteHeader currentPath={currentPath} lang={lang} />

  <main class="flex-1">
    <!-- Back Link -->
    <div class="py-6 px-4 bg-ink-50 dark:bg-ink-800">
      <div class="max-w-4xl mx-auto">
        <a
          href="/en/portfolio"
          class="inline-flex items-center text-ink-600 dark:text-ink-300 hover:text-ink-700 dark:hover:text-ink-200 transition-colors"
        >
          ← Back to Portfolio
        </a>
      </div>
    </div>

    <!-- Image Viewer -->
    <section class="py-12 px-4 bg-white dark:bg-ink-700">
      <div class="max-w-4xl mx-auto">
        <div class="relative aspect-square bg-ink-100 dark:bg-ink-600 rounded-sm overflow-hidden mb-8">
          {hasRealImage ? (
            <img
              src={artwork.full}
              alt={artwork.titleEn}
              class="w-full h-full object-contain"
              id="artwork-image"
            />
          ) : (
            <div
              class="w-full h-full flex items-center justify-center text-ink-700 dark:text-ink-100 hand-drawn"
              style="background-color: var(--paper-bg);"
              set:html={proceduralTile}
            />
          )}
        </div>
      </div>
    </section>

    <!-- Details -->
    <section class="py-12 px-4">
      <div class="max-w-4xl mx-auto grid md:grid-cols-3 gap-12">
        <!-- Left: Content -->
        <div class="md:col-span-2">
          <h1 class="font-display-en text-4xl text-ink-700 dark:text-ink-50 mb-4">
            {artwork.titleEn}
          </h1>

          <p class="font-body text-lg text-ink-600 dark:text-ink-300 mb-8 leading-relaxed">
            {artwork.descEn}
          </p>

          <!-- Techniques -->
          <div class="mb-8">
            <h3 class="font-display-en text-lg text-ink-700 dark:text-ink-50 mb-4">
              Techniques
            </h3>
            <div class="flex flex-wrap gap-2">
              {artwork.techniques.map(tech => (
                <span class="px-3 py-1.5 bg-gold-100 dark:bg-gold-900 text-gold-700 dark:text-gold-200 rounded-sm text-sm">
                  {tech}
                </span>
              ))}
            </div>
          </div>
        </div>

        <!-- Right: Metadata -->
        <aside>
          <!-- Date -->
          <div class="mb-8">
            <h4 class="font-display-en text-sm text-ink-500 dark:text-ink-400 uppercase mb-2">
              Created
            </h4>
            <p class="font-body text-ink-700 dark:text-ink-50">
              {dateStr}
            </p>
          </div>

          <!-- Tangles -->
          <div class="mb-8">
            <h4 class="font-display-en text-sm text-ink-500 dark:text-ink-400 uppercase mb-3">
              Tangles
            </h4>
            <div class="space-y-2">
              {artwork.tangles.map(tangle => (
                <div class="flex items-center gap-2">
                  <span class="w-2 h-2 bg-ink-400 dark:bg-ink-500 rounded-full" />
                  <span class="font-body text-ink-700 dark:text-ink-50">
                    {tangle}
                  </span>
                </div>
              ))}
            </div>
          </div>

          <!-- Featured Badge -->
          {artwork.featured && (
            <div class="px-4 py-3 bg-gold-50 dark:bg-gold-900 border border-gold-200 dark:border-gold-800 rounded-sm">
              <p class="font-body text-sm text-gold-700 dark:text-gold-200 text-center">
                Featured
              </p>
            </div>
          )}
        </aside>
      </div>
    </section>

    <!-- Navigation -->
    <section class="py-12 px-4 border-t border-ink-200 dark:border-ink-700">
      <div class="max-w-4xl mx-auto">
        <div class="grid md:grid-cols-2 gap-8">
          <a
            href={`/en/portfolio/${prevArtwork.id}`}
            class="group block p-6 bg-ink-50 dark:bg-ink-800 rounded-sm hover:bg-ink-100 dark:hover:bg-ink-700 transition-colors"
          >
            <p class="font-body text-sm text-ink-500 dark:text-ink-400 mb-2">Previous Work</p>
            <h3 class="font-display-en text-lg text-ink-700 dark:text-ink-50 group-hover:text-ink-900 dark:group-hover:text-ink-100">
              ← {prevArtwork.titleEn}
            </h3>
          </a>

          <a
            href={`/en/portfolio/${nextArtwork.id}`}
            class="group block p-6 bg-ink-50 dark:bg-ink-800 rounded-sm hover:bg-ink-100 dark:hover:bg-ink-700 transition-colors text-right"
          >
            <p class="font-body text-sm text-ink-500 dark:text-ink-400 mb-2">Next Work</p>
            <h3 class="font-display-en text-lg text-ink-700 dark:text-ink-50 group-hover:text-ink-900 dark:group-hover:text-ink-100">
              {nextArtwork.titleEn} →
            </h3>
          </a>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter lang={lang} />
  <TangleCursor client:idle />
</Layout>
