---
import Layout from '@/layouts/Layout.astro';
import SiteHeader from '@/components/layout/SiteHeader.astro';
import SiteFooter from '@/components/layout/SiteFooter.astro';
import TangleCursor from '@/components/cursor/TangleCursor';

const lang = 'en';
const currentPath = '/en/videos';
const title = 'Zentangle Chou — Video Tutorials';
const description = 'Step-by-step Zentangle demonstrations and creative process';

const videos = [
  {
    id: 1,
    titleZh: 'Crescent Moon 初級教學',
    titleEn: 'Crescent Moon Beginner Tutorial',
    youtubeId: 'dQw4w9WgXcQ',
    descEn: 'Learn the most foundational Zentangle pattern: Crescent Moon. Perfect for beginners.'
  },
  {
    id: 2,
    titleZh: '完整紙磚創作過程',
    titleEn: 'Complete Tile Creation Process',
    youtubeId: 'jNQXAC9IVRw',
    descEn: 'From border to signature, watch how a complete tile is born. Approximately 20 minutes.'
  },
  {
    id: 3,
    titleZh: '暗模式繪製技巧',
    titleEn: 'Shading & Depth Techniques',
    youtubeId: '9bZkp7q19f0',
    descEn: 'Master shading and aura techniques to create dimension. Suited for intermediate learners.'
  }
];
---

<Layout
  title={title}
  description={description}
  lang={lang}
  currentPath={currentPath}
>
  <SiteHeader currentPath={currentPath} lang={lang} />

  <main class="flex-1">
    <!-- Hero -->
    <section class="py-20 px-4 bg-ink-50 dark:bg-ink-800">
      <div class="max-w-4xl mx-auto">
        <h1 class="font-display-en text-4xl md:text-5xl text-ink-700 dark:text-ink-50 mb-4">
          Video Tutorials
        </h1>
        <p class="font-body text-lg text-ink-600 dark:text-ink-300">
          Learn Zentangle techniques and patterns step by step through video demonstrations.
        </p>
      </div>
    </section>

    <!-- Videos Grid -->
    <section class="py-20 px-4">
      <div class="max-w-4xl mx-auto">
        <div class="grid md:grid-cols-1 lg:grid-cols-1 gap-8">
          {videos.map(video => (
            <div class="bg-white dark:bg-ink-700 rounded-sm overflow-hidden shadow-sm hover:shadow-lg transition-shadow">
              <div class="relative w-full aspect-video bg-ink-900">
                <iframe
                  src={`https://www.youtube.com/embed/${video.youtubeId}?rel=0`}
                  title={video.titleEn}
                  class="w-full h-full"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowFullScreen
                  loading="lazy"
                />
              </div>

              <div class="p-6">
                <h3 class="font-display-en text-xl font-semibold text-ink-700 dark:text-ink-50 mb-2">
                  {video.titleEn}
                </h3>
                <p class="font-body text-sm text-ink-500 dark:text-ink-400 mb-3">
                  {video.titleZh}
                </p>
                <p class="font-body text-ink-600 dark:text-ink-300 leading-relaxed">
                  {video.descEn}
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Coming Soon -->
    <section class="py-20 px-4 bg-ink-50 dark:bg-ink-800">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="font-display-en text-2xl text-ink-700 dark:text-ink-50 mb-4">
          More Lessons Coming Soon
        </h2>
        <p class="font-body text-ink-600 dark:text-ink-300 max-w-2xl mx-auto">
          We are preparing more in-depth video lessons covering advanced techniques, creative applications, and special effects. Stay tuned!
        </p>
      </div>
    </section>
  </main>

  <SiteFooter lang={lang} />
  <TangleCursor client:idle />
</Layout>
