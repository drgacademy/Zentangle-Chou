```

#### 6.2.2 Detail 頁（`/tangles/[name]`）

進場動畫：上一頁的卡片 image 用 Framer Motion `layoutId` 變換到大圖位置（500ms shared element transition）。

主要內容已在 Part 3.2.6 列出。step animation 是核心功能，見 6.2.3。

#### 6.2.3 Step Animation 實作

```tsx
// src/components/tangles/TangleStepAnimation.tsx
import { useEffect, useRef, useState } from 'react';

interface Step {
  step: number;
  path_d: string;
  duration: number;
  description?: string;
}

interface Props {
  steps: Step[];
  viewBox?: string;
  loopGap?: number; // 結束後等多久重來
}

export function TangleStepAnimation({ steps, viewBox = '0 0 200 200', loopGap = 1.5 }: Props) {
  const svgRef = useRef<SVGSVGElement>(null);
  const [currentStep, setCurrentStep] = useState(0);
  const [isPlaying, setIsPlaying] = useState(true);

  useEffect(() => {
    if (!svgRef.current || !isPlaying) return;
    let timeouts: number[] = [];

    const playOnce = () => {
      let cumulative = 0;
      steps.forEach((step, i) => {
        const t = setTimeout(() => {
          setCurrentStep(i);
          const path = svgRef.current!.querySelector(`#step-${step.step}`) as SVGPathElement;
          if (!path) return;
          const length = path.getTotalLength();
          path.style.strokeDasharray = `${length}`;
          path.style.strokeDashoffset = `${length}`;
          path.style.opacity = '1';
          path.getBoundingClientRect();
          path.style.transition = `stroke-dashoffset ${step.duration}s ease-out`;
          path.style.strokeDashoffset = '0';
        }, cumulative * 1000) as unknown as number;
        timeouts.push(t);
        cumulative += step.duration;
      });

      // loop
      const loopTimer = setTimeout(() => {
        // reset
        steps.forEach(step => {
          const path = svgRef.current!.querySelector(`#step-${step.step}`) as SVGPathElement;
          if (path) {
            path.style.transition = 'none';
            path.style.opacity = '0';
          }
        });
        setCurrentStep(0);
        setTimeout(() => playOnce(), 100);
      }, (cumulative + loopGap) * 1000) as unknown as number;
      timeouts.push(loopTimer);
    };

    playOnce();
    return () => timeouts.forEach(clearTimeout);
  }, [steps, isPlaying, loopGap]);

  return (
    <div className="relative">
      <svg
        ref={svgRef}
        viewBox={viewBox}
        className="w-full aspect-square bg-ink-50 border border-ink-200 rounded-sm"
        fill="none"
        stroke="currentColor"
        strokeWidth="1.5"
        strokeLinecap="round"
      >
        {steps.map(step => (
          <path
            key={step.step}
            id={`step-${step.step}`}
            d={step.path_d}
            style={{ opacity: 0 }}
          />
        ))}
      </svg>

      <div className="mt-4 flex items-center justify-between">
        <div className="text-sm text-ink-500">
          Step {currentStep + 1} / {steps.length}
          {steps[currentStep]?.description && (
            <span className="ml-2 text-ink-700">— {steps[currentStep].description}</span>
          )}
        </div>
        <button
          onClick={() => setIsPlaying(!isPlaying)}
          className="text-sm text-ink-600 underline"
        >
          {isPlaying ? '暫停' : '重播'}
        </button>
      </div>
    </div>
  );
}
```

### 6.3 Portfolio 瀑布流

#### 6.3.1 Layout

用 CSS Grid `grid-auto-rows: minmax(0, auto)` + JS 計算每張卡片應佔多少 row（依圖片 aspect ratio）。

```tsx
// src/components/portfolio/PortfolioGrid.tsx
import { useEffect, useState } from 'react';
import { motion, AnimatePresence } from 'framer-motion';

interface Artwork { /* ... */ }

export function PortfolioGrid({ artworks }: { artworks: Artwork[] }) {
  const [filter, setFilter] = useState<{ year?: number; mood?: string; tangle?: string }>({});

  const filtered = artworks.filter(a => {
    if (filter.year && a.year !== filter.year) return false;
    if (filter.mood && !a.mood.includes(filter.mood)) return false;
    if (filter.tangle && !a.tangles_used.some(t => t.slug === filter.tangle)) return false;
    return true;
  });

  return (
    <>
      <FilterBar value={filter} onChange={setFilter} />
      <div className="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        <AnimatePresence>
          {filtered.map(a => (
            <motion.div
              key={a.slug}
              layout
              layoutId={`artwork-${a.slug}`}
              initial={{ opacity: 0 }}
              animate={{ opacity: 1 }}
              exit={{ opacity: 0 }}
              className="break-inside-avoid"
            >
              <PortfolioCard artwork={a} />
            </motion.div>
          ))}
        </AnimatePresence>
      </div>
    </>
  );
}
```

實際 masonry 用 CSS columns 比 grid 簡單：

```css
.masonry {
  column-count: 2;
  column-gap: 1rem;
}
@media (min-width: 768px) { .masonry { column-count: 3; } }
@media (min-width: 1024px) { .masonry { column-count: 4; } }
.masonry > * { break-inside: avoid; margin-bottom: 1rem; }
```

#### 6.3.2 hover 動畫

```tsx
// PortfolioCard
<div className="group relative">
  <img src={cover} className="w-full" />
  {/* SVG overlay：hover 時 path drawing */}
  <svg className="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
    <path d={mainTangleOutline} className="hover-draw" />
  </svg>
</div>
```

CSS：

```css
.hover-draw {
  stroke-dasharray: 1000;
  stroke-dashoffset: 1000;
  transition: stroke-dashoffset 0.5s ease-out;
}
.group:hover .hover-draw {
  stroke-dashoffset: 0;
}
```

### 6.4 Video Player

不要用 YouTube 預設嵌入樣式（紅 logo 太喧鬧）。用 `youtube-nocookie.com` + 自訂 thumbnail：

```tsx
// src/components/videos/VideoEmbed.tsx
export function VideoEmbed({ embedId, provider, thumbnail, title }: Props) {
  const [isLoaded, setIsLoaded] = useState(false);

  if (!isLoaded) {
    return (
      <button
        onClick={() => setIsLoaded(true)}
        className="relative w-full aspect-video group"
      >
        <img src={thumbnail} alt={title} className="w-full h-full object-cover" />
        <div className="absolute inset-0 flex items-center justify-center">
          <PlayIcon className="w-16 h-16 text-white/90 group-hover:scale-110 transition-transform" />
        </div>
      </button>
    );
  }

  const url = provider === 'youtube'
    ? `https://www.youtube-nocookie.com/embed/${embedId}?autoplay=1&rel=0&modestbranding=1`
    : `https://player.vimeo.com/video/${embedId}?autoplay=1`;

  return (
    <iframe
      src={url}
      className="w-full aspect-video"
      allow="autoplay; encrypted-media; picture-in-picture"
      allowFullScreen
      title={title}
    />
  );
}
```

### 6.5 雙語切換

#### 6.5.1 URL 結構

`/zh/portfolio/spring-2025` ↔ `/en/portfolio/spring-2025` （slug 共用）

#### 6.5.2 LanguageSwitcher

```astro
---
// src/components/layout/LanguageSwitcher.astro
const { currentPath } = Astro.props;
const isZh = currentPath.startsWith('/zh');
const altPath = isZh
  ? currentPath.replace(/^\/zh/, '/en')
  : currentPath.replace(/^\/en/, '/zh');
---
<a href={altPath} class="lang-switch" hreflang={isZh ? 'en' : 'zh-Hant-TW'}>
  {isZh ? 'English' : '中文'}
</a>
```

#### 6.5.3 hreflang

每頁 `<head>`：

```astro
<link rel="alternate" hreflang="zh-Hant-TW" href={`https://drg-academy.com/zh${path}`} />
<link rel="alternate" hreflang="en" href={`https://drg-academy.com/en${path}`} />
<link rel="alternate" hreflang="x-default" href={`https://drg-academy.com/en${path}`} />
```

### 6.6 暗 / 淺模式切換

切換動畫：整個畫面 `rotateY(180deg)`（1 秒），同時 `theme` class 切換——感覺像翻轉一張紙磚。

```tsx
// src/components/layout/ThemeToggle.tsx
export function ThemeToggle() {
  const [theme, setTheme] = useState<'light' | 'dark'>('light');

  const toggle = () => {
    document.documentElement.style.transition = 'transform 1s cubic-bezier(0.4, 0, 0.2, 1)';
    document.documentElement.style.transform = 'rotateY(180deg)';
    setTimeout(() => {
      const next = theme === 'light' ? 'dark' : 'light';
      document.documentElement.classList.toggle('dark', next === 'dark');
      setTheme(next);
      localStorage.setItem('theme', next);
      document.documentElement.style.transform = 'rotateY(0deg)';
    }, 500);
  };

  return (
    <button onClick={toggle} aria-label="切換主題">
      {theme === 'light' ? <MoonIcon /> : <SunIcon />}
    </button>
  );
}
```

### 6.7 行動版

#### 6.7.1 Bottom navigation

行動版底部固定 5 個 icon：Home / Portfolio / Tangles / About / Menu。

```tsx
// src/components/layout/MobileNav.tsx
<nav className="fixed bottom-0 inset-x-0 bg-ink-50/95 backdrop-blur border-t border-ink-200 md:hidden z-50">
  <div className="grid grid-cols-5">
    {[
      { href: '/', icon: HomeIcon, label: '首頁' },
      { href: '/portfolio', icon: GalleryIcon, label: '作品' },
      { href: '/tangles', icon: GridIcon, label: '字典' },
      { href: '/about', icon: PersonIcon, label: '關於' },
      { href: '#menu', icon: MenuIcon, label: '更多' },
    ].map(item => (
      <a key={item.href} href={item.href} className="flex flex-col items-center py-3">
        <item.icon className="w-6 h-6" />
        <span className="text-[10px] mt-1">{item.label}</span>
      </a>
    ))}
  </div>
</nav>
```

#### 6.7.2 Touch target

所有可點元素最小 44×44 px（iOS HIG）。Tailwind: `min-h-[44px]` + `min-w-[44px]`。

#### 6.7.3 動畫降級

行動版 disable `TangleCursor`、hero 動畫總時長壓到 5 秒、portfolio hover 動畫改為 tap 觸發。

### 6.8 Accessibility（WCAG 2.1 AA）

| 項目 | 落實方式 |
|---|---|
| **色彩對比** | 已在 2.1.5 確認 |
| **鍵盤導航** | 所有互動元素 `tabIndex`、可見 `:focus` outline（不刪 outline，改成 ink-700 1px） |
| **ARIA labels** | 所有圖示按鈕 `aria-label`；所有 SVG `role="img"` + `<title>` |
| **動畫** | `prefers-reduced-motion` 全面尊重 |
| **alt text** | 每張作品 alt 描述「使用了什麼 tangle、mood」 |
| **語言** | `<html lang="zh-Hant-TW">` 或 `lang="en"` |
| **跳到主內容** | 鍵盤使用者第一個 Tab `<a href="#main">Skip to content</a>` |

