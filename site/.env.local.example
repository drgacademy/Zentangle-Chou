# Sanity Cloud — get these from your project at https://sanity.io/manage
# After running `pnpm sanity init` once, copy the values shown here.

SANITY_PROJECT_ID=
SANITY_DATASET=production

# Read token (used at build time to fetch published content). Optional —
# without it, public datasets work via the CDN with no token.
SANITY_API_READ_TOKEN=

# Write token (used only by scripts/seed-sanity.ts to push the initial JSON
# data. Never commit this; never expose to the browser.)
SANITY_API_WRITE_TOKEN=

# These mirror the above for the `sanity` CLI itself
SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production
