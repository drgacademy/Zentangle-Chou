---
import Layout from '@/layouts/Layout.astro';
import SiteHeader from '@/components/layout/SiteHeader.astro';
import SiteFooter from '@/components/layout/SiteFooter.astro';
import HeroAnimation from '@/components/hero/HeroAnimation';
import ScrollCue from '@/components/common/ScrollCue';
import ScrollReveal from '@/components/common/ScrollReveal';
import Tile from '@/components/common/Tile.astro';
import TangleCursor from '@/components/cursor/TangleCursor';
import { useT } from '@/i18n/useT';
import { withBase } from '@/lib/withBase';

const t = useT('en');
const lang = 'en';
const currentPath = '/en/';
const heroImage = withBase('/artworks/hero-tile.jpg');
---

<Layout
  title={t('site.title')}
  description={t('site.description')}
  lang={lang}
  currentPath={currentPath}
>
  <SiteHeader currentPath={currentPath} lang={lang} />

  <main class="flex-1 relative z-10">
    <!-- Hero Section -->
    <section class="relative min-h-screen flex items-center justify-center px-4 overflow-hidden">
      <div class="w-full max-w-3xl">
        <HeroAnimation client:visible title={t('hero.title')} subtitle={t('hero.subtitle')} imageSrc={heroImage} />
      </div>
      <ScrollCue client:visible />
    </section>

    <!-- About Zentangle Section -->
    <section id="zentangle-intro" class="py-20 px-4 bg-ink-50 dark:bg-ink-800">
      <div class="max-w-3xl mx-auto">
        <ScrollReveal client:visible drawBorder={true}>
          <h2 class="font-display-en text-3xl md:text-4xl text-ink-700 dark:text-ink-50 mb-8 text-center">
            {t('homepage.section_about')}
          </h2>
          <p class="font-body text-base md:text-lg text-ink-600 dark:text-ink-300 leading-relaxed text-center">
            {t('homepage.about_intro')}
          </p>
        </ScrollReveal>
      </div>
    </section>

    <!-- Three Entry Points -->
    <section class="py-20 px-4">
      <div class="max-w-4xl mx-auto">
        <ScrollReveal client:visible drawBorder={false}>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <Tile
              title="Portfolio"
              description="Browse my Zentangle creations and discover the stories behind each piece."
              href="/en/portfolio"
              lang="en"
            />
            <Tile
              title="Tangle Dictionary"
              description="41 classic tangle patterns with detailed tutorials and animated demonstrations."
              href="/en/tangles"
              lang="en"
            />
            <Tile
              title="About Me"
              description="Learn about my Zentangle journey and creative philosophy."
              href="/en/about"
              lang="en"
            />
          </div>
        </ScrollReveal>
      </div>
    </section>

    <!-- Featured Works (Placeholder) -->
    <section class="py-20 px-4 bg-ink-50 dark:bg-ink-800">
      <div class="max-w-4xl mx-auto">
        <ScrollReveal client:visible drawBorder={true}>
          <h2 class="font-display-en text-3xl md:text-4xl text-ink-700 dark:text-ink-50 mb-12 text-center">
            {t('homepage.section_featured')}
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {[1, 2, 3].map(i => (
              <div key={i} class="aspect-square bg-ink-200 dark:bg-ink-700 rounded-sm animate-pulse flex items-center justify-center">
                <p class="text-ink-400 dark:text-ink-500">Work {i}</p>
              </div>
            ))}
          </div>
        </ScrollReveal>
      </div>
    </section>

    <!-- Quote Section -->
    <section class="py-20 px-4">
      <div class="max-w-3xl mx-auto text-center">
        <ScrollReveal client:visible drawBorder={false}>
          <blockquote class="font-body text-lg md:text-xl text-ink-600 dark:text-ink-300 italic mb-6">
            "{t('homepage.section_quote')}"
          </blockquote>
          <p class="font-body text-sm text-ink-500 dark:text-ink-400">
            — {t('homepage.quote_author')}
          </p>
        </ScrollReveal>
      </div>
    </section>
  </main>

  <SiteFooter lang={lang} />
  <TangleCursor client:idle />
</Layout>
