---
interface Props {
  id: number;
  titleZh: string;
  titleEn: string;
  descZh: string;
  descEn: string;
  thumbnail: string;
  date: string;
  tangles: string[];
  lang: 'zh' | 'en';
}

const { id, titleZh, titleEn, descZh, descEn, thumbnail, date, tangles, lang } = Astro.props;

const title = lang === 'zh' ? titleZh : titleEn;
const desc = lang === 'zh' ? descZh : descEn;
const detailLink = lang === 'zh' ? `/zh/portfolio/${id}` : `/en/portfolio/${id}`;
const dateObj = new Date(date);
const dateStr = lang === 'zh'
  ? `${dateObj.getFullYear()}年${dateObj.getMonth() + 1}月${dateObj.getDate()}日`
  : dateObj.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<a
  href={detailLink}
  class="group block bg-white dark:bg-ink-700 rounded-sm overflow-hidden shadow-sm hover:shadow-lg transition-shadow"
  transition:name={`artwork-${id}`}
>
  <!-- 圖片區域 -->
  <div class="relative aspect-square bg-ink-100 dark:bg-ink-600 overflow-hidden">
    <img
      src={thumbnail}
      alt={title}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
      loading="lazy"
    />

    <!-- Overlay - 浮現效果 -->
    <div class="absolute inset-0 bg-black opacity-0 group-hover:opacity-30 transition-opacity duration-300" />
  </div>

  <!-- 文字區域 -->
  <div class="p-4">
    <!-- 標題 -->
    <h3 class="font-display-zh md:font-display-en text-lg font-semibold text-ink-700 dark:text-ink-50 mb-2 line-clamp-1">
      {title}
    </h3>

    <!-- 描述 -->
    <p class="font-body text-sm text-ink-600 dark:text-ink-300 mb-3 line-clamp-2">
      {desc}
    </p>

    <!-- 圖樣標籤 -->
    <div class="flex flex-wrap gap-1 mb-3">
      {tangles.slice(0, 2).map(tangle => (
        <span class="inline-block px-2 py-1 text-xs bg-ink-100 dark:bg-ink-600 text-ink-700 dark:text-ink-200 rounded">
          {tangle}
        </span>
      ))}
      {tangles.length > 2 && (
        <span class="inline-block px-2 py-1 text-xs text-ink-500 dark:text-ink-400">
          +{tangles.length - 2}
        </span>
      )}
    </div>

    <!-- 日期 -->
    <p class="font-body text-xs text-ink-400 dark:text-ink-500">
      {dateStr}
    </p>
  </div>
</a>
