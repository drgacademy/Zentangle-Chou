---
interface Props {
  lang: 'zh' | 'en';
}

const { lang } = Astro.props;

const links = lang === 'zh'
  ? {
      learn: [
        { label: '什麼是禪繞畫', href: '/zh/about' },
        { label: '圖樣字典', href: '/zh/tangles' },
        { label: '創作流程', href: '/zh/process' },
      ],
      connect: [
        { label: 'Instagram', href: 'https://instagram.com' },
        { label: 'Email', href: 'mailto:contact@example.com' },
      ],
      about: [
        { label: '關於創作者', href: '/zh/about' },
        { label: '隱私政策', href: '/zh/privacy' },
      ],
    }
  : {
      learn: [
        { label: 'What is Zentangle', href: '/en/about' },
        { label: 'Tangle Dictionary', href: '/en/tangles' },
        { label: 'Process', href: '/en/process' },
      ],
      connect: [
        { label: 'Instagram', href: 'https://instagram.com' },
        { label: 'Email', href: 'mailto:contact@example.com' },
      ],
      about: [
        { label: 'About Artist', href: '/en/about' },
        { label: 'Privacy', href: '/en/privacy' },
      ],
    };

const currentYear = new Date().getFullYear();
const copyright = lang === 'zh'
  ? `© ${currentYear} YuChiao Chou. All rights reserved.`
  : `© ${currentYear} YuChiao Chou. All rights reserved.`;
---

<footer class="mt-auto border-t border-ink-200 dark:border-ink-600 bg-ink-50 dark:bg-ink-900 text-ink-600 dark:text-ink-400 py-12">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Footer Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
      <!-- Learn -->
      <div>
        <h3 class="text-ink-700 dark:text-ink-100 font-semibold mb-4 font-display-zh">
          {lang === 'zh' ? '學習' : 'Learn'}
        </h3>
        <ul class="space-y-2">
          {links.learn.map(link => (
            <li>
              <a href={link.href} class="text-sm hover:text-sepia-500 dark:hover:text-sepia-300 transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Connect -->
      <div>
        <h3 class="text-ink-700 dark:text-ink-100 font-semibold mb-4 font-display-zh">
          {lang === 'zh' ? '聯絡' : 'Connect'}
        </h3>
        <ul class="space-y-2">
          {links.connect.map(link => (
            <li>
              <a href={link.href} class="text-sm hover:text-sepia-500 dark:hover:text-sepia-300 transition-colors" target="_blank" rel="noopener">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- About -->
      <div>
        <h3 class="text-ink-700 dark:text-ink-100 font-semibold mb-4 font-display-zh">
          {lang === 'zh' ? '關於' : 'About'}
        </h3>
        <ul class="space-y-2">
          {links.about.map(link => (
            <li>
              <a href={link.href} class="text-sm hover:text-sepia-500 dark:hover:text-sepia-300 transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Copyright -->
    <div class="text-center pt-8 border-t border-ink-200 dark:border-ink-600">
      <p class="text-xs text-ink-400 dark:text-ink-500">
        {copyright}
      </p>
    </div>
  </div>
</footer>
