---
import { getT } from '@lib/i18n';
import LanguageSwitcher from './LanguageSwitcher.astro';
import ThemeToggle from './ThemeToggle';

interface Props {
  lang: 'zh' | 'en';
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const t = getT(lang);
const basePath = lang === 'zh' ? '/zh' : '/en';

const navItems = [
  { label: t.nav.home, href: `${basePath}/` },
  { label: t.nav.portfolio, href: `${basePath}/portfolio` },
  { label: t.nav.tangles, href: `${basePath}/tangles` },
  { label: t.nav.videos, href: `${basePath}/videos` },
  { label: t.nav.process, href: `${basePath}/process` },
  { label: t.nav.about, href: `${basePath}/about` },
  { label: t.nav.contact, href: `${basePath}/contact` },
];

const isActive = (href: string) => {
  return currentPath === href || currentPath.startsWith(href + '/');
};
---

<header class="sticky top-0 z-40 bg-ink-50 dark:bg-ink-900 border-b border-ink-200 dark:border-ink-700">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex items-center justify-between">
    {/* Logo */}
    <a href={`${basePath}/`} class="flex items-center gap-2 font-display-zh text-2xl text-ink-700 dark:text-ink-100 hover:text-sepia-500">
      禪繞
    </a>

    {/* Nav Items */}
    <div class="hidden md:flex items-center gap-8">
      {navItems.map((item) => (
        <a
          href={item.href}
          class={`text-sm font-body transition-colors ${
            isActive(item.href)
              ? 'text-ink-700 dark:text-ink-50 font-semibold'
              : 'text-ink-500 dark:text-ink-400 hover:text-sepia-500 dark:hover:text-sepia-300'
          }`}
        >
          {item.label}
        </a>
      ))}
    </div>

    {/* Right Actions */}
    <div class="flex items-center gap-4">
      <LanguageSwitcher currentPath={currentPath} lang={lang} />
      <ThemeToggle client:idle />
    </div>
  </nav>
</header>
