---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

// Extract language and rest of path
const isZh = currentPath.startsWith('/zh');
const pathWithoutLang = currentPath.replace(/^\/(zh|en)/, '');

const zhUrl = `/zh${pathWithoutLang}`;
const enUrl = `/en${pathWithoutLang}`;
---

<div class="flex gap-2">
  <a
    href={zhUrl}
    hreflang="zh-Hant"
    class={`px-3 py-1 text-sm rounded transition-colors ${
      isZh
        ? 'bg-ink-200 dark:bg-ink-700 text-ink-700 dark:text-ink-50 font-semibold'
        : 'text-ink-500 dark:text-ink-400 hover:text-ink-600 dark:hover:text-ink-300'
    }`}
  >
    中文
  </a>
  <a
    href={enUrl}
    hreflang="en"
    class={`px-3 py-1 text-sm rounded transition-colors ${
      !isZh
        ? 'bg-ink-200 dark:bg-ink-700 text-ink-700 dark:text-ink-50 font-semibold'
        : 'text-ink-500 dark:text-ink-400 hover:text-ink-600 dark:hover:text-ink-300'
    }`}
  >
    EN
  </a>
</div>
